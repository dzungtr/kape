FROM golang:1.23-alpine AS builder
WORKDIR /workspace
COPY go.work go.work.sum ./
COPY adapters/ adapters/
RUN go build -o /out/kape-adapter-audit ./adapters/cmd/audit/...

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /out/kape-adapter-audit /kape-adapter-audit
ENTRYPOINT ["/kape-adapter-audit"]
