FROM golang:1.23-alpine AS builder
WORKDIR /workspace
COPY go.work go.work.sum ./
COPY adapters/ adapters/
RUN go build -o /out/kape-adapter-falco ./adapters/cmd/falco/...

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /out/kape-adapter-falco /kape-adapter-falco
ENTRYPOINT ["/kape-adapter-falco"]
